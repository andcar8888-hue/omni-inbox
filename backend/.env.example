#--------------------------------------------------------------------
# Omni-Inbox backend environment configuration
#
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored — never commit real credentials.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'

#--------------------------------------------------------------------
# DATABASE (MySQL 8, InnoDB, utf8mb4 — see docs/db-schema.sql)
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = omni_inbox
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

database.tests.hostname = localhost
database.tests.database = omni_inbox_test
database.tests.username = root
database.tests.password =
database.tests.DBDriver = MySQLi
database.tests.DBPrefix =
database.tests.charset = utf8mb4
database.tests.DBCollat = utf8mb4_general_ci
database.tests.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key =

#--------------------------------------------------------------------
# AUTH (JWT for the API — see CLAUDE.md)
#--------------------------------------------------------------------

# JWT_SECRET =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4
